#!/bin/sh

set -eu

tmpdir=$(mktemp -d)
trap 'rm -rf "$tmpdir"' EXIT
trap 'exit 1' HUP INT TERM

markdown=$tmpdir/clipboard.md
normalized=$tmpdir/normalized.md
pdf=$tmpdir/preview.pdf
log=$tmpdir/pandoc.log
data_dir=${XDG_DATA_HOME:-$HOME/.local/share}/markdown-preview

case $# in
	0)
		if ! xclip -selection clipboard -out >"$markdown" 2>"$log"; then
			notify-send --urgency=critical "Markdown preview failed" \
				"$(tail -n 8 "$log")"
			exit 1
		fi
		if [ ! -s "$markdown" ]; then
			notify-send --urgency=critical "Markdown preview" "The clipboard does not contain text."
			exit 1
		fi
		;;
	1)
		if [ ! -r "$1" ] || [ ! -s "$1" ]; then
			notify-send --urgency=critical "Markdown preview" "The input file is missing or empty."
			exit 1
		fi
		markdown=$1
		;;
	*)
		notify-send --urgency=critical "Markdown preview" "Usage: markdown-preview [FILE]"
		exit 1
		;;
esac

if ! python3 -c \
	'import html, sys; sys.stdout.write(html.unescape(sys.stdin.read()))' \
	<"$markdown" >"$normalized" 2>"$log"
then
	notify-send --urgency=critical "Markdown preview failed" \
		"Could not normalize the input. $(tail -n 8 "$log")"
	exit 1
fi

if ! pandoc \
	--from=markdown+tex_math_single_backslash-citations+autolink_bare_uris \
	--lua-filter="$data_dir/html.lua" \
	--lua-filter="$data_dir/typst-math.lua" \
	--pdf-engine=typst \
	--metadata-file="$data_dir/typst.yaml" \
	--output="$pdf" \
	"$normalized" 2>"$log"
then
	notify-send --urgency=critical "Markdown preview failed" \
		"Pandoc could not convert the input. $(tail -n 8 "$log")"
	exit 1
fi

mupdf -I "$pdf"
