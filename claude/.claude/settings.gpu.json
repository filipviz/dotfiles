{
  "statusLine": {
    "type": "command",
    "command": "sh ~/.claude/statusline-command.sh"
  },
  "permissions": {
    "defaultMode": "bypassPermissions"
  },
  "env": {
    "IS_SANDBOX": "1"
  },
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "model": "claude-fable-5[1m]",
  "effortLevel": "high",
  "preferredNotifChannel": "notifications_disabled",
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "sh \"$HOME/.claude/tmux-notify.sh\" prompt",
            "async": true,
            "timeout": 10
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "sh \"$HOME/.claude/tmux-notify.sh\" notification",
            "async": true,
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "sh \"$HOME/.claude/tmux-notify.sh\" stop",
            "async": true,
            "timeout": 10
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "sh \"$HOME/.claude/tmux-notify.sh\" clear",
            "timeout": 10
          }
        ]
      }
    ]
  },
  "theme": "auto",
  "editorMode": "vim"
}
